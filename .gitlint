# gitlint configuration. Run `gitlint` or install as a commit-msg hook
# with `gitlint install-hook`. Docs: https://jorisroovers.com/gitlint/

[general]
# Match the forward-compatible regex semantics (search, not match).
regex-style-search=true
# Keep going after the first failure so all issues surface at once.
ignore-merge-commits=true
ignore-fixup-commits=true
ignore-squash-commits=true
verbosity=3

[title-max-length]
line-length=60

[title-min-length]
min-length=10

[title-must-not-contain-word]
# Reject low-signal subjects.
words=wip,stuff,things,misc,temp

[title-trailing-punctuation]

[title-trailing-whitespace]

[title-leading-whitespace]

[body-max-line-length]
line-length=80

[body-min-length]
min-length=0

[body-trailing-whitespace]

[ignore-by-title]
# Allow auto-generated revert subjects to skip body rules.
regex=^Revert
ignore=body-min-length
